<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <PlatformTarget>x64</PlatformTarget>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Lib.Harmony" Version="2.4.2" />
    <PackageReference Include="StarMap.API" Version="0.3.6" />
  </ItemGroup>

  <ItemGroup>
    <Reference Include="KSA">
      <HintPath>..\..\..\refs\game\KSA.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Brutal.Core.Numerics">
      <HintPath>..\..\..\refs\game\Brutal.Core.Numerics.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- double3.Transform(doubleQuat), used to project an orbit position into the parent frame for
         the map-mode overlay, has a sibling overload referencing BepuUtilities' Symmetric3x3, so
         overload resolution needs this assembly on the reference path even though we never use it. -->
    <Reference Include="BepuUtilities">
      <HintPath>..\..\..\refs\game\BepuUtilities.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <!-- Provides the Ptr type used in some ImGui overload signatures (e.g. InputTextWithHint);
         needed for overload resolution even when calling the ImInputString overload. -->
    <Reference Include="Brutal.Core.Common">
      <HintPath>..\..\..\refs\game\Brutal.Core.Common.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Brutal.Core.Logging">
      <HintPath>..\..\..\refs\game\Brutal.Core.Logging.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="Brutal.ImGui">
      <HintPath>..\..\..\refs\game\Brutal.ImGui.dll</HintPath>
      <Private>false</Private>
    </Reference>
    <Reference Include="CommunityToolkit.HighPerformance">
      <HintPath>..\..\..\refs\game\CommunityToolkit.HighPerformance.dll</HintPath>
      <Private>false</Private>
    </Reference>
  </ItemGroup>

  <ItemGroup>
    <None Update="mod.toml">
      <CopyToOutputDirectory>Always</CopyToOutputDirectory>
    </None>
  </ItemGroup>

  <Target Name="CopyToMods" AfterTargets="Build">
    <PropertyGroup>
      <ModDir>$(USERPROFILE)\Documents\My Games\Kitten Space Agency\mods\DeltaVMap\</ModDir>
    </PropertyGroup>
    <MakeDir Directories="$(ModDir)" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(ModDir)" />
    <Copy SourceFiles="mod.toml" DestinationFolder="$(ModDir)" />
  </Target>

  <Target Name="PackageRelease" AfterTargets="Build" Condition="'$(Configuration)' == 'Release'">
    <PropertyGroup>
      <ReleaseDir>$(OutputPath)release\$(AssemblyName)\</ReleaseDir>
      <ZipPath>$(OutputPath)$(AssemblyName).zip</ZipPath>
    </PropertyGroup>
    <RemoveDir Directories="$(OutputPath)release" />
    <MakeDir Directories="$(ReleaseDir)" />
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).dll" DestinationFolder="$(ReleaseDir)" />
    <Copy SourceFiles="mod.toml" DestinationFolder="$(ReleaseDir)" />
    <ZipDirectory SourceDirectory="$(OutputPath)release" DestinationFile="$(ZipPath)" Overwrite="true" />
    <RemoveDir Directories="$(OutputPath)release" />
    <Message Importance="high" Text="Release packaged: $(ZipPath)" />
  </Target>

</Project>
